<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.springblade.vlstream.mapper.VlsSceneGovernanceMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="vlsSceneGovernanceResultMap" type="org.springblade.vlstream.pojo.entity.SceneGovernance">
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="cron_expression" property="cronExpression"/>
        <result column="location" property="location"/>
        <result column="cameras" property="cameras"/>
    </resultMap>

    <select id="selectVlsSceneGovernancePage" resultMap="vlsSceneGovernanceResultMap">
        select * from vls_scene_governance where is_deleted = 0 order by create_time desc
    </select>

    <select id="exportVlsSceneGovernance" resultType="org.springblade.vlstream.excel.VlsSceneGovernanceExcel">
        SELECT * FROM vls_scene_governance ${ew.customSqlSegment}
    </select>

</mapper>
